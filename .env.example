# MongoDB Connection String (Required)
MONGO_URI=mongodb+srv://Dubai:ab1ab2ab3@cluster0.mgmzmip.mongodb.net/reatEstate

# Server Port (optional, default 4001)
PORT=4001

# JWT Secrets (Required - generate strong secrets)
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_SECRET=your-access-token-secret-change-this
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this

# JWT Token Expiry
JWT_ACCESS_SECRET_EXPIRY=15m
JWT_REFRESH_SECRET_EXPIRY=7d

# Email Configuration (Gmail) - Optional
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=https://appraisalsassets-client-delta.vercel.app

# Google OAuth - Optional
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Default Admin Credentials
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-admin-password

# Allowed Origins (comma-separated for CORS)
ALLOWED_ORIGINS=https://your-client.vercel.app,http://localhost:3000