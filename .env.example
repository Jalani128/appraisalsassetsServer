# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/awr-properties

# Server Port (optional, defaults to 4001)
PORT=4001

# JWT Secrets
JWT_SECRET=your-jwt-secret-key-here
JWT_ACCESS_SECRET=your-jwt-access-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here

# JWT Token Expiry
JWT_ACCESS_SECRET_EXPIRY=15m
JWT_REFRESH_SECRET_EXPIRY=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Default Admin Credentials (for initial setup)
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@awr-properties.com
ADMIN_PASSWORD=your-secure-admin-password
