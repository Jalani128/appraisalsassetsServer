# MongoDB Atlas Connection String
# Example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=

# Server Port (local development only; Vercel ignores custom PORT values)
PORT=4001

# JWT Secrets
JWT_ACCESS_SECRET=your-jwt-access-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here

# JWT Token Expiry
JWT_ACCESS_SECRET_EXPIRY=15m
JWT_REFRESH_SECRET_EXPIRY=7d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email Configuration (Gmail or SMTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL (production)
# Set this to your deployed frontend domain, e.g. https://www.assetsappraisals.com
FRONTEND_URL=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Default Admin Credentials (for initial setup)
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@awr-properties.com
ADMIN_PASSWORD=your-secure-admin-password
